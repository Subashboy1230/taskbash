# =========================================
# Week 1 environment. Copy to .env.local and fill in.
# =========================================

# --- Supabase ---
# Project URL — settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Service role key — settings → API → service_role (NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Anon key — for client-side use later when we add UI
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- Nango ---
# Secret key — Nango dashboard → environment settings
NANGO_SECRET_KEY=
# Provider config keys (the integration IDs you create in Nango dashboard)
NANGO_GRANOLA_PROVIDER_KEY=granola
# Gmail integration — create a "Google Mail" integration in Nango, then put
# its provider config key here (Nango's default for this provider is google-mail).
NANGO_GMAIL_PROVIDER_KEY=google-mail

# --- Inngest ---
# Event key — Inngest dashboard → keys → event keys
INNGEST_EVENT_KEY=
# Signing key — Inngest dashboard → keys → signing keys
INNGEST_SIGNING_KEY=

# --- Anthropic ---
# API key — console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=

# --- Granola (direct API, not via Nango) ---
# Granola → Settings → Workspaces → API tab → Generate API Key.
# Requires Granola Enterprise plan for API access.
GRANOLA_API_KEY=

# --- App ---
# YOUR user_id from the users table (created by the seed insert in migration-001).
# Hardcoded for Week 1 — auth comes later.
APP_USER_ID=00000000-0000-0000-0000-000000000001
# The Nango connection ID for YOUR Granola account (you'll get this after Nango Connect UI flow).
APP_NANGO_GRANOLA_CONNECTION_ID=
# The Nango connection ID for YOUR Gmail account (you'll get this after the Nango Connect flow).
APP_NANGO_GMAIL_CONNECTION_ID=

# --- Twilio / WhatsApp ---
# Twilio account SID — console.twilio.com → Account info → Account SID
TWILIO_ACCOUNT_SID=
# Twilio auth token — console.twilio.com → Account info → Auth Token
TWILIO_AUTH_TOKEN=
# WhatsApp sender in Twilio format: whatsapp:+E164 (with country code).
# e.g. whatsapp:+14155551234. Set after the WhatsApp sender is approved.
TWILIO_WHATSAPP_FROM=
# Content SIDs for the two Meta-approved templates. Get these after
# Twilio Content Template Builder → submit → Meta approves (24-48h).
TWILIO_TEMPLATE_MORNING_DIGEST_SID=
TWILIO_TEMPLATE_MEETING_REMINDER_SID=
# Optional. If you use a Messaging Service (recommended for production),
# its SID takes precedence over TWILIO_WHATSAPP_FROM.
# TWILIO_MESSAGING_SERVICE_SID=

# --- Local dev ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Sentry (error tracking) ---
# DSN for server + edge runtimes. Sentry dashboard -> Settings -> Projects ->
# taskbash -> Client Keys (DSN). If unset, the SDK no-ops (no events sent).
SENTRY_DSN=
# Same DSN value, exposed to the browser bundle for client-side errors.
NEXT_PUBLIC_SENTRY_DSN=
# Org and project slugs — used only at build time for source-map upload.
SENTRY_ORG=
SENTRY_PROJECT=taskbash
# Auth token for uploading source maps during build (CI/Vercel). Optional for
# local dev — builds succeed without it, you just get minified stack traces.
# Sentry dashboard -> Settings -> Auth Tokens (needs project:releases scope).
SENTRY_AUTH_TOKEN=
